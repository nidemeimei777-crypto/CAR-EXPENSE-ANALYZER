# Настройки JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGO=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Настройки приложения
APP_TITLE=Car Expense Analyzer API
APP_VERSION=1.0.0
DEBUG=False

# Дополнительные параметры
DEFAULT_REMINDER_STEP_KM=10000
DEFAULT_FUEL_CONSUMPTION_LAST_N=5

# Настройки базы данных (заглушки для CSV-версии)
db_username=postgres
db_password=postgres
db_host=localhost
db_port=5432
db_name=car_expenses
